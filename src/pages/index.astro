---
import Layout from '../layouts/Layout.astro';
---

<Layout title="WebCloner - 备份你需要的一切" lang="zh-CN">
  <main>
    <header class="sticky top-0 z-50 glass">
      <div class="container flex h-14 items-center justify-between">
        <a href="/" class="flex items-center gap-2 font-bold">
          <img src="/favicon.svg" alt="WebCloner" class="h-6 w-6" />
          <span>WebCloner</span>
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm text-foreground/80">
          <a href="#features" class="hover:text-primary">功能</a>
          <a href="#demo" class="hover:text-primary">演示</a>
          <a href="#download" class="hover:text-primary">下载</a>
          <a href="https://blog.bytefuse.cn/M2XYdbunIouhGsxxNOkcfdiGnvh" target="_blank" rel="noopener noreferrer" class="hover:text-primary">文档</a>
        </nav>
        <a id="header-download" href="#download" class="rounded-xl px-4 py-2 text-sm font-medium bg-primary text-primary-foreground">开始使用</a>
      </div>
    </header>

    <section class="container py-16 md:py-24">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-6xl font-bold tracking-tight">
          备份你需要的一切
        </h1>
        <p class="mt-5 text-base md:text-lg text-muted-foreground">
          WebCloner 是一个强大的工具，可以帮你备份网站内容，包括：微博、博客、小红书、抖音等。
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a id="hero-download" href="#" class="rounded-xl px-6 py-3 font-medium bg-primary text-primary-foreground disabled:opacity-50">直接下载使用</a>
          <a href="#demo" class="rounded-xl px-6 py-3 font-medium glass">查看演示</a>
        </div>
      </div>
    </section>

    <section class="container pb-8 md:pb-12">
      <div class="glass rounded-2xl p-6 md:p-10">
        <div class="text-sm font-semibold">支持平台</div>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-8 md:gap-12">
          {[
            { icon: 'icon-sina', name: '新浪微博' },
            { icon: 'icon-xueqiu', name: '雪球' },
            { icon: 'icon-sina', name: '新浪博客' },
            { icon: 'icon-xiaohongshu', name: '小红书' },
            { icon: 'icon-douyin', name: '抖音' },
            { icon: 'icon-qqzone', name: 'QQ空间' },
            { icon: 'icon-qqzone', name: 'QQ说说' },
          ].map((p) => (
            <div class="flex flex-col items-center gap-2">
              <div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-primary/5 ring-1 ring-primary/10">
                <svg class="h-10 w-10 fill-foreground" aria-hidden="true"><use href={`#${p.icon}`}></use></svg>
              </div>
              <span class="text-xs md:text-sm text-foreground/80">{p.name}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="container pb-8 md:pb-8">
      <div class="glass rounded-2xl p-6 md:p-10">
        <div class="text-sm font-semibold">支持保存内容</div>
        <div class="mt-4 flex flex-wrap gap-3">
          {['文字', '图片', '视频', '评论', '转发', '专辑'].map((item) => (
            <span class="rounded-full bg-primary/10 px-4 py-1.5 text-sm text-foreground/80">{item}</span>
          ))}
        </div>
        <p class="mt-4 text-sm text-muted-foreground">
          如有其它需求可以联系我：<a href="tencent://message/?uin=2246855973&Site=&Menu=yes" class="text-primary hover:underline">QQ 2246855973</a>
        </p>
      </div>
    </section>

    <section id="features" class="container py-8 md:py-24">
      <h2 class="text-2xl md:text-4xl font-bold">功能特性</h2>
      <p class="mt-3 text-muted-foreground">简单清晰的流程：选择平台 → 登录/授权 → 一键备份 → 本地保存</p>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="glass rounded-2xl p-6">
          <div class="font-semibold">软件首页</div>
          <div class="mt-2 text-sm text-muted-foreground">功能简单直观，易于上手。</div>
        </div>
        <div class="glass rounded-2xl p-6">
          <div class="font-semibold">账号管理</div>
          <div class="mt-2 text-sm text-muted-foreground">模拟浏览器登录，保存平台账号信息，方便后续使用。</div>
        </div>
        <div class="glass rounded-2xl p-6">
          <div class="font-semibold">任务管理</div>
          <div class="mt-2 text-sm text-muted-foreground">批量备份任务，支持配置规则与深度（产品展示页不实现后台逻辑）。</div>
        </div>
      </div>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-3 gap-6">
        <img class="rounded-2xl shadow-2xl w-full h-auto" src="/images/home.png" alt="home" loading="lazy" />
        <img class="rounded-2xl shadow-2xl w-full h-auto" src="/images/account.png" alt="account" loading="lazy" />
        <img class="rounded-2xl shadow-2xl w-full h-auto" src="/images/task.png" alt="task" loading="lazy" />
      </div>
    </section>

    <section id="demo" class="container py-16 md:py-24">
      <h2 class="text-2xl md:text-4xl font-bold">演示</h2>
      <p class="mt-3 text-muted-foreground">以下为产品效果展示</p>
      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 gap-6">
        <img class="rounded-2xl shadow-2xl w-full h-auto" src="/images/weibo.gif" alt="weibo demo" loading="lazy" />
        <img class="rounded-2xl shadow-2xl w-full h-auto" src="/images/douyin.gif" alt="douyin demo" loading="lazy" />
        <img class="rounded-2xl shadow-2xl w-full h-auto" src="/images/redbook.gif" alt="redbook demo" loading="lazy" />
        <img class="rounded-2xl shadow-2xl w-full h-auto" src="/images/sinablog.gif" alt="sinablog demo" loading="lazy" />
      </div>
    </section>

    <section id="download" class="container py-16 md:py-24">
      <div class="glass rounded-2xl p-8 md:p-12 flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <h2 class="text-2xl md:text-4xl font-bold">立即开始使用</h2>
          <p class="mt-3 text-muted-foreground">点击按钮下载客户端</p>
        </div>
        <a id="cta-download" href="#" class="rounded-xl px-6 py-3 font-medium bg-primary text-primary-foreground">下载</a>
      </div>
    </section>

    <footer class="container py-10 text-sm text-muted-foreground">
      <div class="border-t pt-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2">
        <span>© 2024 WebCloner. 保留所有权利.</span>
        <a href="tencent://message/?uin=2246855973&Site=&Menu=yes" class="hover:text-primary">联系QQ: 2246855973</a>
      </div>
    </footer>
  </main>

  <script is:inline>
    (async function () {
      try {
        const res = await fetch('https://www.bytefuse.cn/clonerweb.json', { cache: 'no-store' });
        const data = await res.json();
        // console.log(data);
        const url = data && data.app_download_url ? String(data.app_download_url) : '';
        if (!url) return;
        for (const id of ['hero-download', 'cta-download', 'header-download']) {
          const el = document.getElementById(id);
          if (!el) continue;
          el.setAttribute('href', url);
          el.setAttribute('target', '_blank');
          el.setAttribute('rel', 'noopener noreferrer');
        }
      } catch (e) {
        // ignore
      }
    })();
  </script>
</Layout>
